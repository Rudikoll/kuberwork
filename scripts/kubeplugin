#!/bin/bash

set -e

# ==============================
# kubectl kubeplugin <namespace> <resource>
# ==============================

NAMESPACE=$1
RESOURCE=$2

# Перевірка аргументів
if [[ -z "$NAMESPACE" || -z "$RESOURCE" ]]; then
  echo "Usage: kubectl kubeplugin <namespace> <resource>"
  exit 1
fi

# Заголовок
echo "Resource, Namespace, Name, CPU, Memory"

# Отримання метрик
kubectl top $RESOURCE -n $NAMESPACE --no-headers | while read -r line
do
  NAME=$(echo "$line" | awk '{print $1}')
  CPU=$(echo "$line" | awk '{print $2}')
  MEMORY=$(echo "$line" | awk '{print $3}')

  echo "$RESOURCE, $NAMESPACE, $NAME, $CPU, $MEMORY"
done
